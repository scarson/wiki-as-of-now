 | archive-date = 5 March 2016
 | archive-url = https://web.archive.org/web/20160305153044/http://ec.europa.eu/competition/state_aid/cases/251157/251157_1507977_35_2.pdf
 | url-status = live
 }}</ref><ref name="wnn-20131218">{{cite news
